<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>黄金价格实时监控</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Vue.js -->
    <script src="/modules/vue.global.js"></script>
    
    <!-- 自定义科幻风格CSS -->
    <link rel="stylesheet" href="/static/css/style.css">
</head>

    <script src="/modules/vue.global.js"></script>


</head>

<body class="min-h-screen p-4">

    <div id="app" class="max-w-7xl mx-auto">

        <!-- 标题 -->

        <div class="text-center mb-6">

            <h1 class="text-3xl font-bold glow-text-cyan mb-2">黄金价格监控系统</h1>

            <div class="title-divider"></div>

        </div>

        <!-- 配置区域 -->

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">

            <div class="glow-card p-4 rounded-lg">

                <div class="text-sm text-gray-400 mb-2">买入金价</div>

                <input v-model="buy_price" type="number" step="0.1" class="w-full px-3 py-2 input-glow rounded data-value">

                <div class="text-xs text-gray-500 mt-1">元/克</div>

            </div>

            <div class="glow-card p-4 rounded-lg">

                <div class="text-sm text-gray-400 mb-2">买入克数</div>

                <input v-model="buy_weight" type="number" step="0.001" class="w-full px-3 py-2 input-glow rounded data-value">

                <div class="text-xs text-gray-500 mt-1">克</div>

            </div>

            <div class="glow-card p-4 rounded-lg">

                <div class="text-sm text-gray-400 mb-2">监控频率</div>

                <div class="flex space-x-2">

                    <input v-model="interval" type="number" class="flex-1 px-3 py-2 input-glow rounded data-value">

                    <button v-if="is_running" @click="updateInterval" class="px-3 py-2 btn-glow rounded text-sm">更新</button>

                </div>

                <div class="text-xs text-gray-500 mt-1">秒</div>

            </div>

            <div class="glow-card p-4 rounded-lg">

                <div class="text-sm text-gray-400 mb-2">监控控制</div>

                <button @click="toggleMonitor"
                    :class="is_running ? 'btn-glow-stop' : 'btn-glow'"
                    class="w-full py-2 rounded font-bold data-value">

                    <span v-text="is_running ? '停止监控' : '开始监控'"></span>

                </button>

                <div class="flex items-center justify-center mt-2 space-x-2">

                    <input v-model="push_all" type="checkbox" id="push_all" class="w-4 h-4">

                    <label for="push_all" class="text-xs text-gray-400">推送通知</label>

                </div>

            </div>

        </div>

        <!-- 状态显示 -->

        <div v-if="is_running" class="mb-6">

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

                <!-- 当前金价 -->

                <div class="glow-card-yellow p-4 rounded-lg">

                    <div class="section-title mb-2">当前金价</div>

                    <div class="data-value glow-text-yellow">

                        <span v-text="gold_price.toFixed(2)"></span>

                        <span class="text-sm text-gray-400 ml-1">元/克</span>

                    </div>

                    <div class="text-xs text-gray-500 mt-1">更新时间: <span v-text="last_update"></span></div>

                </div>

                <!-- 实际盈亏 -->

                <div :class="profit_with_fee >= 0 ? 'glow-card-green' : 'glow-card-red'" class="p-4 rounded-lg">

                    <div class="section-title mb-2">实际盈亏</div>

                    <div :class="profit_with_fee >= 0 ? 'glow-text-green' : 'glow-text-red'" class="data-value">

                        <span v-text="profit_with_fee >= 0 ? '+' : ''"></span>

                        <span v-text="profit_with_fee.toFixed(2)"></span>

                        <span class="text-sm text-gray-400 ml-1">元</span>

                    </div>

                    <div class="text-xs text-gray-500 mt-1">

                        盈利率: <span :class="profit_with_fee >= 0 ? 'glow-text-green' : 'glow-text-red'">

                            <span v-text="profit_with_fee >= 0 ? '+' : ''"></span>

                            <span v-text="((profit_with_fee / (buy_price * buy_weight)) * 100).toFixed(2)"></span>%

                        </span>

                    </div>

                </div>

                <!-- 详细信息 -->

                <div class="glow-card p-4 rounded-lg">

                    <div class="section-title mb-2">详细信息</div>

                    <div class="space-y-1 text-sm">

                        <div class="flex justify-between">

                            <span class="text-gray-400">浮动盈亏:</span>

                            <span class="glow-text-cyan" v-text="profit.toFixed(2)"></span>

                            <span class="text-gray-500 text-xs">元</span>

                        </div>

                        <div class="flex justify-between">

                            <span class="text-gray-400">手续费:</span>

                            <span class="glow-text-red" v-text="fee_amount.toFixed(2)"></span>

                            <span class="text-gray-500 text-xs">元</span>

                        </div>

                        <div class="flex justify-between">

                            <span class="text-gray-300" v-text="(buy_price * buy_weight).toFixed(2)"></span>

                            <span class="text-gray-500 text-xs">元</span>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- 趋势图和日志并排 -->

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- 趋势图 -->

            <div v-if="is_running && priceHistory.length > 1" class="chart-container p-4 rounded-lg">

                <div class="section-title mb-4">价格趋势</div>

                <div class="h-48">

                    <canvas id="priceChart"></canvas>

                </div>

            </div>

            <!-- 监控日志 -->

            <div class="log-container p-4 rounded-lg">

                <div class="section-title mb-4">监控日志</div>

                <div class="h-48 overflow-y-auto text-sm font-mono text-gray-300 space-y-1">

                    <div v-for="(log, index) in logs" :key="index" class="border-b border-gray-800/50 pb-1">

                        <span v-text="log" :class="log.includes('提醒') ? 'glow-text-yellow' : ''"></span>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        const { createApp, ref, onMounted, watch, nextTick } = Vue;

        createApp({

            setup() {

                // 从localStorage获取缓存的配置

                const getStoredConfig = () => {

                    try {

                        const stored = localStorage.getItem('gold_monitor_config');

                        if (stored) {

                            return JSON.parse(stored);

                        }

                    } catch (e) {

                        console.log('读取配置失败，使用默认值');

                    }

                    return {

                        buy_price: 1043.0,

                        buy_weight: 20.0,

                        interval: 20,

                        push_all: false

                    };

                };

                const config = getStoredConfig();

                const buy_price = ref(config.buy_price);

                const buy_weight = ref(config.buy_weight);

                const interval = ref(config.interval);

                const push_all = ref(config.push_all);

                const gold_price = ref(0.0);

                const profit = ref(0.0);

                const profit_with_fee = ref(0.0);

                const fee_amount = ref(0.0);

                const last_update = ref('尚未开始');

                const is_running = ref(false);

                const logs = ref([]);

                // 价格历史数据用于图表

                const priceHistory = ref([]);

                const timeHistory = ref([]);

                let chart = null;

                // 监听配置变化，自动保存到localStorage

                watch([buy_price, buy_weight, interval, push_all], () => {

                    try {

                        localStorage.setItem('gold_monitor_config', JSON.stringify({

                            buy_price: buy_price.value,

                            buy_weight: buy_weight.value,

                            interval: interval.value,

                            push_all: push_all.value

                        }));

                    } catch (e) {

                        console.log('保存配置失败');

                    }

                });

                const fetchStatus = async () => {

                    try {

                        const res = await fetch('/status');

                        const data = await res.json();

                        gold_price.value = data.gold_price;

                        profit.value = data.profit;

                        profit_with_fee.value = data.profit_with_fee || data.profit;

                        fee_amount.value = data.fee_amount || 0;

                        last_update.value = data.last_update;

                        is_running.value = data.is_running;

                        logs.value.splice(0, logs.value.length, ...data.logs);

                        // 更新价格历史

                        if (is_running.value && gold_price.value > 0) {

                            const now = new Date().toLocaleTimeString('zh-CN', { hour12: false });

                            if (priceHistory.value.length === 0 || priceHistory.value[priceHistory.value.length - 1] !== gold_price.value) {

                                priceHistory.value.push(gold_price.value);

                                timeHistory.value.push(now);

                                if (priceHistory.value.length > 20) {

                                    priceHistory.value.shift();

                                    timeHistory.value.shift();

                                }

                                updateChart();

                            }

                        }

                    } catch (e) {

                        console.error("获取状态失败", e);

                    }

                };

                const toggleMonitor = async () => {

                    if (is_running.value) {

                        await fetch('/stop', { method: 'POST' });

                        priceHistory.value = [];

                        timeHistory.value = [];

                    } else {

                        await fetch('/start', {

                            method: 'POST',

                            headers: { 'Content-Type': 'application/json' },

                            body: JSON.stringify({

                                buy_price: buy_price.value,

                                buy_weight: buy_weight.value,

                                interval: interval.value,

                                push_all: push_all.value

                            })

                        });

                    }

                    await fetchStatus();

                };

                const updateInterval = async () => {

                    await fetch('/update', {

                        method: 'POST',

                        headers: { 'Content-Type': 'application/json' },

                        body: JSON.stringify({ interval: interval.value })

                    });

                    await fetchStatus();

                };

                const updateChart = async () => {

                    if (priceHistory.value.length < 2) return;

                    await nextTick();

                    const canvas = document.getElementById('priceChart');

                    if (!canvas) return;

                    const ctx = canvas.getContext('2d');

                    const rect = canvas.parentElement.getBoundingClientRect();

                    canvas.width = rect.width;

                    canvas.height = rect.height;

                    ctx.clearRect(0, 0, canvas.width, canvas.height);

                    const padding = 30;

                    const chartWidth = canvas.width - padding * 2;

                    const chartHeight = canvas.height - padding * 2;

                    const minPrice = Math.min(...priceHistory.value);

                    const maxPrice = Math.max(...priceHistory.value);

                    const priceRange = maxPrice - minPrice || 1;

                    // 绘制网格

                    ctx.strokeStyle = 'rgba(56, 189, 248, 0.2)';

                    ctx.lineWidth = 1;

                    for (let i = 0; i <= 5; i++) {

                        const y = padding + (chartHeight * i / 5);

                        ctx.beginPath();

                        ctx.moveTo(padding, y);

                        ctx.lineTo(canvas.width - padding, y);

                        ctx.stroke();

                    }

                    // 绘制数据线

                    ctx.strokeStyle = '#38bdf8';

                    ctx.lineWidth = 2;

                    ctx.shadowColor = '#38bdf8';

                    ctx.shadowBlur = 10;

                    ctx.beginPath();

                    priceHistory.value.forEach((price, index) => {

                        const x = padding + (index / (priceHistory.value.length - 1)) * chartWidth;

                        const y = canvas.height - padding - ((price - minPrice) / priceRange) * chartHeight;

                        if (index === 0) {

                            ctx.moveTo(x, y);

                        } else {

                            ctx.lineTo(x, y);

                        }

                    });

                    ctx.stroke();

                    ctx.shadowBlur = 0;

                    // 绘制数据点

                    priceHistory.value.forEach((price, index) => {

                        const x = padding + (index / (priceHistory.value.length - 1)) * chartWidth;

                        const y = canvas.height - padding - ((price - minPrice) / priceRange) * chartHeight;

                        ctx.fillStyle = '#38bdf8';

                        ctx.shadowColor = '#38bdf8';

                        ctx.shadowBlur = 10;

                        ctx.beginPath();

                        ctx.arc(x, y, 3, 0, 2 * Math.PI);

                        ctx.fill();

                        ctx.shadowBlur = 0;

                    });

                };

                onMounted(() => {

                    fetchStatus();

                    setInterval(fetchStatus, 3000);

                });

                return {

                    buy_price, buy_weight, interval, push_all,

                    gold_price, profit, profit_with_fee, fee_amount, last_update, is_running, logs,

                    priceHistory, timeHistory,

                    toggleMonitor, updateInterval

                };

            }

        }).mount('#app');

    </script>

</body>

</html>